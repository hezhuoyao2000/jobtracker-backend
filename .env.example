# 数据库配置
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_secure_password

# 开发环境数据库端口映射（宿主机:容器）
DB_PORT=5432

# 生产环境数据库外部端口（用于数据库管理工具连接，生产环境建议移除）
DB_EXTERNAL_PORT=5432

# JWT 密钥（生产环境请使用强随机字符串）
# 生成方法: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here

# 应用端口（默认 8080）
APP_PORT=8080

# JVM 参数（可选）
# JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# CORS 跨域配置（开发环境）
# 允许访问的前端域名（按顺序配置，可配置多个）
CORS_ALLOWED_ORIGIN_1=http://localhost:3000
CORS_ALLOWED_ORIGIN_2=http://localhost:5173
CORS_ALLOWED_ORIGIN_3=https://your-production-domain.com

# ============================================
# CORS 跨域配置（生产环境）
# 配置允许访问的前端域名
# ============================================
# CORS_ALLOWED_ORIGIN_1=https://www.your-production-domain.com
# CORS_ALLOWED_ORIGIN_2=https://your-production-domain.com
# CORS_ALLOWED_ORIGIN_3=https://your-another-domain.com