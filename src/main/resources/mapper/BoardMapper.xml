<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.myfirstspringboot.mapper.BoardMapper">

    <!-- BoardDataDto 结果映射 -->
    <resultMap id="BoardDataResultMap" type="com.example.myfirstspringboot.dto.response.BoardDataDto">
        <association property="board" resultMap="BoardMap"/>
        <collection property="columns" resultMap="ColumnMap"/>
        <collection property="cards" resultMap="JobCardMap"/>
    </resultMap>

    <!-- BoardDto 映射 -->
    <resultMap id="BoardMap" type="com.example.myfirstspringboot.dto.response.BoardDto">
        <id property="id" column="board_id" javaType="java.util.UUID" typeHandler="com.example.myfirstspringboot.config.UuidTypeHandler"/>
        <result property="userId" column="user_id"/>
        <result property="name" column="board_name"/>
        <result property="createdAt" column="board_created_at"/>
        <result property="updatedAt" column="board_updated_at"/>
    </resultMap>

    <!-- ColumnDto 映射 -->
    <resultMap id="ColumnMap" type="com.example.myfirstspringboot.dto.response.ColumnDto">
        <id property="id" column="column_id" javaType="java.util.UUID" typeHandler="com.example.myfirstspringboot.config.UuidTypeHandler"/>
        <result property="boardId" column="column_board_id" javaType="java.util.UUID" typeHandler="com.example.myfirstspringboot.config.UuidTypeHandler"/>
        <result property="name" column="column_name"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="isDefault" column="is_default"/>
        <result property="customAttributes" column="custom_attributes" javaType="java.util.Map" typeHandler="com.example.myfirstspringboot.config.JsonbTypeHandler"/>
    </resultMap>

    <!-- JobCardDto 映射 -->
    <resultMap id="JobCardMap" type="com.example.myfirstspringboot.dto.response.JobCardDto">
        <id property="id" column="card_id" javaType="java.util.UUID" typeHandler="com.example.myfirstspringboot.config.UuidTypeHandler"/>
        <result property="boardId" column="card_board_id" javaType="java.util.UUID" typeHandler="com.example.myfirstspringboot.config.UuidTypeHandler"/>
        <result property="statusId" column="status_id" javaType="java.util.UUID" typeHandler="com.example.myfirstspringboot.config.UuidTypeHandler"/>
        <result property="jobTitle" column="job_title"/>
        <result property="companyName" column="company_name"/>
        <result property="jobLink" column="job_link"/>
        <result property="sourcePlatform" column="source_platform"/>
        <result property="expired" column="expired"/>
        <result property="jobLocation" column="job_location"/>
        <result property="description" column="description"/>
        <result property="appliedTime" column="applied_time"/>
        <result property="tags" column="tags" javaType="java.util.List" typeHandler="com.example.myfirstspringboot.config.StringArrayTypeHandler"/>
        <result property="comments" column="comments"/>
        <result property="extra" column="extra" javaType="java.util.Map" typeHandler="com.example.myfirstspringboot.config.JsonbTypeHandler"/>
        <result property="createdAt" column="card_created_at"/>
        <result property="updatedAt" column="card_updated_at"/>
    </resultMap>

    <!-- 根据用户 ID 查询看板完整数据 -->
    <select id="findBoardDataByUserId" resultMap="BoardDataResultMap">
        SELECT 
            -- Board 字段
            b.id AS board_id,
            b.user_id,
            b.name AS board_name,
            b.created_at AS board_created_at,
            b.updated_at AS board_updated_at,
            -- Column 字段
            c.id AS column_id,
            c.board_id AS column_board_id,
            c.name AS column_name,
            c.sort_order,
            c.is_default,
            c.custom_attributes,
            -- JobCard 字段
            j.id AS card_id,
            j.board_id AS card_board_id,
            j.status_id,
            j.job_title,
            j.company_name,
            j.job_link,
            j.source_platform,
            j.expired,
            j.job_location,
            j.description,
            j.applied_time,
            j.tags,
            j.comments,
            j.extra,
            j.created_at AS card_created_at,
            j.updated_at AS card_updated_at
        FROM board b
        LEFT JOIN kanban_column c ON c.board_id = b.id
        LEFT JOIN job_card j ON j.board_id = b.id AND j.deleted_at IS NULL
        WHERE b.user_id = #{userId}
        ORDER BY c.sort_order ASC, j.created_at DESC
    </select>

    <!-- 根据看板 ID 查询完整数据 -->
    <select id="findBoardDataByBoardId" resultMap="BoardDataResultMap">
        SELECT 
            -- Board 字段
            b.id AS board_id,
            b.user_id,
            b.name AS board_name,
            b.created_at AS board_created_at,
            b.updated_at AS board_updated_at,
            -- Column 字段
            c.id AS column_id,
            c.board_id AS column_board_id,
            c.name AS column_name,
            c.sort_order,
            c.is_default,
            c.custom_attributes,
            -- JobCard 字段
            j.id AS card_id,
            j.board_id AS card_board_id,
            j.status_id,
            j.job_title,
            j.company_name,
            j.job_link,
            j.source_platform,
            j.expired,
            j.job_location,
            j.description,
            j.applied_time,
            j.tags,
            j.comments,
            j.extra,
            j.created_at AS card_created_at,
            j.updated_at AS card_updated_at
        FROM board b
        LEFT JOIN kanban_column c ON c.board_id = b.id
        LEFT JOIN job_card j ON j.board_id = b.id AND j.deleted_at IS NULL
        WHERE b.id = #{boardId} AND b.user_id = #{userId}
        ORDER BY c.sort_order ASC, j.created_at DESC
    </select>

</mapper>
