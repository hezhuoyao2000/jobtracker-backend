{
  "compaction": {
  "auto": true,
  "strategy": "summarize",
  "threshold": 0.8,
  "prune_tool_outputs": true
  },
  
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-dc19142f-5a6f-4fae-8bd3-86a86b2f2e5b"
      },
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }

  },

  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@zenobius/opencode-skillful"
  ],
  


  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow"
  },

  "instructions": [".cursor/rules/react-rule.mdc"]
}